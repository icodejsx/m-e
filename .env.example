# M&E platform environment variables
# Copy this file to .env.local and adjust as needed.

# Origin of the backend that the Next.js proxy forwards to.
# Used by the rewrite in next.config.ts: /be-api/* -> ${BACKEND_ORIGIN}/api/*
# This is a SERVER-side variable; changes require restarting `next dev`.
BACKEND_ORIGIN=https://app-service.icadpays.com

# Server-side only (e.g. .env.local / Vercel). Leave empty here — never put a real key in this file.
OPENAI_API_KEY=

# AI analytics API (/api/ai-analytics)
# - On Vercel: add OPENAI_API_KEY (Production + Preview as needed). Mark sensitive.
# - Set BACKEND_ORIGIN to the same API origin you use in production so session checks work.
# - Session verification runs automatically when NODE_ENV=production unless you set:
#     AI_ANALYTICS_REQUIRE_AUTH=false
# - Force verification in local dev:
#     AI_ANALYTICS_REQUIRE_AUTH=true
AI_ANALYTICS_REQUIRE_AUTH=

# Optional: override the base URL the browser uses.
# Leave unset to use the same-origin proxy (/be-api) and avoid CORS.
# Set to an absolute URL only if your backend sends proper CORS headers.
# NEXT_PUBLIC_API_BASE_URL=https://app-service.icadpays.com/api
